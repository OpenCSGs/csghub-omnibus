#!/bin/bash -e

# Redirect stderr -> stdout
exec 2>&1

# Exit if execute with any errors
set -e

# Run pre-start hooks before any other initialization to allow them to set up necessary files and permissions.
csghub-ctl hook pre-start logger

{{- $runUser := (datasource "run_user").run_user }}

exec chpst -e /opt/csghub/service/minio/env -P \
  -u {{ $runUser }}:{{ $runUser }} \
  /opt/csghub/embedded/bin/logger