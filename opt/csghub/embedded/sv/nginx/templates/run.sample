#!/bin/bash

# Redirect stderr -> stdout
exec 2>&1

# fail on errors
set -e

{{- $dataDir := .nginx.data | default "/var/opt/csghub/nginx" }}
cd {{ $dataDir }}
exec chpst -e /opt/csghub/service/nginx/env -P \
    -u {{ .run_user }}:{{ .run_user }} \
    /opt/csghub/embedded/bin/nginx -c {{ $dataDir }}/nginx.conf -g "pid {{ $dataDir }}/nginx.pid; lock_file {{ $dataDir }}/nginx.lock; daemon off;"
