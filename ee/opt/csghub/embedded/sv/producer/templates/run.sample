#!/bin/bash

# Redirect stderr -> stdout
exec 2>&1

# Run the pre-start script to ensure that the service meets the startup conditions
if [ -x ./pre-start ]; then
  ./pre-start
fi

# fail on errors
set -e

{{- $runUser := (datasource "run_user").run_user }}

cd /opt/csghub/embedded/sv/web/project
exec chpst -e /opt/csghub/service/web/env -P \
  -u {{ $runUser }}:{{ $runUser }} \
  /opt/csghub/embedded/bin/celery -A config beat --loglevel=INFO